				"hooks": [
					{
						"type": "command",
						"command": "memorix.cmd hook",
						"timeout": 10
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "memorix.cmd hook",
						"timeout": 10
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "memorix.cmd hook",
						"timeout": 10
					}
				]
			}
		]
