			{
				"hooks": [
					{
						"type": "command",
						"command": "memorix.cmd hook",
						"timeout": 10
					}
				]
			}
		],
		"PostToolUse": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "memorix.cmd hook",
						"timeout": 10
					}
				]
			}
		],
		"UserPromptSubmit": [
