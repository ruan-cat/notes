{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build:docs": {
			"cache": true,
			"outputs": ["**/.vercel/output/**", "**/.vuepress/dist/**", "**/.vitepress/dist/**"],
			"dependsOn": ["^build:docs"]
		},
		"//#deploy:vercel": {
			"cache": false,
			"dependsOn": ["^build:docs"]
		},
		"do-build-note-doc": {
			"cache": true,
			"outputs": ["docs/ruan-cat-notes/docs/.vitepress/dist/**"],
			"dependsOn": ["@ruan-cat-docs/notes#build:docs"]
		},
		"do-build-01star-doc": {
			"cache": true,
			"outputs": ["docs/docs-01-star/docs/.vitepress/dist/**"],
			"dependsOn": ["@ruan-cat-docs/docs-01-star#build:docs"]
		},
		"do-build-my-pr-doc": {
			"cache": true,
			"outputs": ["docs/my-pull-requests/.vercel/output/**"],
			"dependsOn": ["@ruan-cat-docs/my-pull-requests#build:docs"]
		}
	}
}
