{
	"name": "@ruan-cat-docs/my-pull-requests",
	"type": "module",
	"private": true,
	"version": "0.0.1",
	"author": "阮喵喵",
	"license": "MIT",
	"description": "阮喵喵在github的全部commit和pr汇总站点，以 atinux/my-pull-requests 项目为模板制作。",
	"scripts": {
		"dev": "nuxi dev",
		"build": "pnpm run build:vercel",
		"build:docs": "pnpm run build:vercel",
		"build:vercel": "cross-env NODE_OPTIONS=--max-old-space-size=8192 nuxi build --preset vercel",
		"turbo:build:vercel": "turbo run move-vercel-output-to-root --filter=@ruan-cat-docs/my-pull-requests",
		"move-vercel-output-to-root": "move-vercel-output-to-root",
		"postinstall": "nuxi prepare",
		"lint": "eslint .",
		"typecheck": "vue-tsc --noEmit"
	},
	"dependencies": {
		"@dotenvx/dotenvx": "^1.55.1",
		"@iconify-json/lucide": "^1.2.98",
		"@iconify-json/simple-icons": "^1.2.74",
		"@nuxt/ui": "^4.5.1",
		"@vercel/analytics": "^1.6.1",
		"@vercel/speed-insights": "^1.3.1",
		"@vueuse/core": "^13.9.0",
		"@vueuse/nuxt": "^13.9.0",
		"feed": "^5.2.0",
		"nuxt": "^4.4.2",
		"octokit": "^5.0.5",
		"tailwindcss": "^4.2.1",
		"ufo": "^1.6.3",
		"vue": "^3.5.30",
		"vue-router": "^4.6.4"
	},
	"devDependencies": {
		"@nuxt/eslint": "^1.15.2",
		"cross-env": "^7.0.3",
		"eslint": "^9.39.4",
		"shx": "^0.4.0",
		"typescript": "^5.9.3",
		"vue-tsc": "^3.2.5"
	}
}
